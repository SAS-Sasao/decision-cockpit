# =====================================================================
# Decision Cockpit — 環境変数テンプレート
# 実値はここに書かない。コピーして .env(gitignore 済み)に設定する。
# =====================================================================

# --- Database: Neon Postgres + pgvector ---
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- Embeddings: 多言語モデルを1つに固定(混在禁止) ---
EMBEDDING_MODEL=__multilingual_embedding_model__
EMBEDDING_DIM=1024
EMBEDDING_API_KEY=__set_me__

# --- GitHub: SSoT(cc-sier-organization / ai-war-room)の読み取り専用 PAT ---
GITHUB_TOKEN=__read_only_pat__

# --- ai-war-room への書き戻し(Claude Action 用・最小スコープ PAT) ---
WARROOM_PAT=__scoped_pat_for_pr__

# --- Neon 管理 / MCP(開発時) ---
NEON_API_KEY=__set_me__

# --- Anthropic(Claude Action / claude-code-action) ---
ANTHROPIC_API_KEY=__set_me__
