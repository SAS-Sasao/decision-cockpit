{
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push:*--force-with-lease*)",
      "Write(../cc-sier-organization/**)",
      "Edit(../cc-sier-organization/**)",
      "Write(../ai-war-room/**)",
      "Edit(../ai-war-room/**)",
      "Write(.env)",
      "Edit(.env)",
      "Write(.env.local)",
      "Edit(.env.local)",
      "Write(.env.development)",
      "Edit(.env.development)",
      "Write(.env.production)",
      "Edit(.env.production)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(vercel --prod:*)",
      "Bash(vercel deploy --prod:*)",
      "mcp__neon__complete_database_migration"
    ],
    "allow": [
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx next:*)",
      "mcp__neon__create_branch",
      "mcp__neon__run_sql",
      "mcp__neon__prepare_database_migration"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-write.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-verify.sh" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "echo '[SubagentStop / agent判定(雛形)] サブエージェントの成果物が契約(@.claude/rules と対象設計)を満たすか、acceptance-judge で独立検証すること。未検証なら verify-acceptance を実行。' >&2" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "echo '[Stop / agent判定(雛形)] 完了前に現在の /goal の受け入れ条件を acceptance-judge(/verify-acceptance)で独立検証すること。' >&2" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/load-context.sh" }
        ]
      }
    ]
  }
}
