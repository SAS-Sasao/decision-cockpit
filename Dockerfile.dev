# 開発用イメージ(ホットリロード前提)。
# ソースは docker-compose の bind mount で渡すため、ここでは依存だけ入れる。
FROM node:22-bookworm-slim

WORKDIR /app

# 依存を先に入れてレイヤキャッシュを効かせる(ソース変更で再インストールしない)
COPY package.json package-lock.json ./
RUN npm ci

# 実ソースは compose の volume(.:/app)でマウントする。
# /app/node_modules は匿名 volume で保護し、ホスト側で上書きされないようにする。
EXPOSE 3000

# 0.0.0.0 で待受してコンテナ外(localhost:3000)から到達できるようにする
CMD ["npm", "run", "dev", "--", "-H", "0.0.0.0", "-p", "3000"]
